rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly allow anyone to create a login record
    // We remove all complex type checks for now to identify if rules are the bottleneck
    match /logins/{loginId} {
      allow create: if true;
      allow list, get, update, delete: if request.auth != null && request.auth.token.email == "admin@gmail.com";
    }

    match /catalogs/{catalogId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "admin@gmail.com";
    }

    match /customers/{customerId} {
      allow read, write: if request.auth != null && request.auth.token.email == "admin@gmail.com";
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
