rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /logins/{loginId} {
      allow create: if true;
      allow list, get, update, delete: if request.auth != null && (request.auth.token.email == "admin@gmail.com" || request.auth.token.email == "viewer@gmail.com");
    }

    match /catalogs/{catalogId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "admin@gmail.com";
    }

    match /customers/{customerId} {
      allow read: if request.auth != null && (request.auth.token.email == "admin@gmail.com" || request.auth.token.email == "viewer@gmail.com");
      allow write: if request.auth != null && request.auth.token.email == "admin@gmail.com";
    }

    match /inspections/{id} {
      allow read: if request.auth != null && (request.auth.token.email == "admin@gmail.com" || request.auth.token.email == "viewer@gmail.com");
      allow write: if request.auth != null && request.auth.token.email == "admin@gmail.com";
    }

    match /contracted_customers/{id} {
      allow read: if request.auth != null && (request.auth.token.email == "admin@gmail.com" || request.auth.token.email == "viewer@gmail.com");
      allow write: if request.auth != null && request.auth.token.email == "admin@gmail.com";
    }

    match /non_contracted_customers/{id} {
      allow read: if request.auth != null && (request.auth.token.email == "admin@gmail.com" || request.auth.token.email == "viewer@gmail.com");
      allow write: if request.auth != null && request.auth.token.email == "admin@gmail.com";
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
