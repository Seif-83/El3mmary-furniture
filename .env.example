# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase configuration for the El-3mmary project.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
# Optional deployment aliases supported by the Vite build:
# SUPABASE_URL="https://your-project-ref.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"
# NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ADMIN_EMAIL: The email for the furniture company admin.
ADMIN_EMAIL="admin@gmail.com"

# VIEWER_EMAIL: Read-only dashboard user email.
VIEWER_EMAIL="view@gmail.com"

# ADMIN_PASSWORD: Optional legacy variable. The current client login uses the real password
# stored for the admin user in Supabase Auth, not this env var.
ADMIN_PASSWORD="admin123"
