# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase configuration for the El-3mmary project.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
# Optional deployment aliases supported by the Vite build:
# SUPABASE_URL="https://your-project-ref.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"
# NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Optional Supabase storage bucket name used for contract image uploads.
# Set this if your project does not use a bucket named "contracts".
VITE_SUPABASE_CONTRACTS_BUCKET="contracts"

# ADMIN_EMAIL: The email for the furniture company admin.
ADMIN_EMAIL="admin@gmail.com"

# VIEWER_EMAIL: Read-only dashboard user email.
VIEWER_EMAIL="view@gmail.com"

# ADMIN_PASSWORD: Optional legacy variable. The current client login uses the real password
# stored for the admin user in Supabase Auth, not this env var.
ADMIN_PASSWORD="admin123"

# Optional Vite admin fallback used by the client for initial admin checks
VITE_ADMIN_EMAIL="admin@example.com"

# (Optional) Supabase service role for programmatic migrations/seeding
# WARNING: keep this secret and DO NOT commit it to source control
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
